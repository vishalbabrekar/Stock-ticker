String extractToken(const String &data, int targetIndex) {
  int currentSegment = 0, startPos = 0;
  for (int i = 0; i <= data.length(); i++) {
    if (i == data.length() || data.charAt(i) == ',') {
      if (currentSegment == targetIndex) { String extracted = data.substring(startPos, i); extracted.trim(); return extracted; }
      startPos = i + 1; currentSegment++;
    }
  }
  return "";
}

String buildStockString(Stock* list, int i, int count) {
  if (i >= count) return "";
  return list[i].symbol + " " + list[i].price + ((list[i].change.indexOf('-') != -1) ? "  v " : "  ^ ") + list[i].change + " %      ";
}

