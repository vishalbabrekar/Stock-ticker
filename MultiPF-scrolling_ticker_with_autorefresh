        preCalculateAllDimensions(); dataNeedsUpdate = false; xSemaphoreGive(dataMutex); 
      }
    }
    if (babaCount > 0 && widthBaba > 0) {
      spriteBaba.fillSprite(TFT_BLACK); int tx = scrollBabaX;
      while (tx < 480) {
        for (int i = 0; i < babaCount; i++) {
          if (tx + wBaba[i] >= 0 && tx < 480) { spriteBaba.setTextColor(cBaba[i], TFT_BLACK); spriteBaba.drawString(buildStockString(babaList, i, babaCount), tx, 15); }
          tx += wBaba[i]; if (tx >= 480) break;
        }
      }
      spriteBaba.pushSprite(0, 20); scrollBabaX -= 2; if (scrollBabaX < -widthBaba) scrollBabaX += widthBaba;
    }
    if (aaiCount > 0 && widthAai > 0) {
      spriteAai.fillSprite(TFT_BLACK); int tx = scrollAaiX;
      while (tx < 480) {
        for (int i = 0; i < aaiCount; i++) {
          if (tx + wAai[i] >= 0 && tx < 480) { spriteAai.setTextColor(cAai[i], TFT_BLACK); spriteAai.drawString(buildStockString(aaiList, i, aaiCount), tx, 15); }
          tx += wAai[i]; if (tx >= 480) break;
        }
      }
      spriteAai.pushSprite(0, 130); scrollAaiX -= 3; if (scrollAaiX < -widthAai) scrollAaiX += widthAai;
    }
    if (niftyCount > 0 && widthNifty > 0) {
      spriteNifty.fillSprite(TFT_BLACK); int tx = scrollNiftyX;
      while (tx < 480) {
        for (int i = 0; i < niftyCount; i++) {
          if (tx + wNifty[i] >= 0 && tx < 480) { spriteNifty.setTextColor(cNifty[i], TFT_BLACK); spriteNifty.drawString(buildStockString(niftyList, i, niftyCount), tx, 15); }
          tx += wNifty[i]; if (tx >= 480) break;
        }
      }
      spriteNifty.pushSprite(0, 240); scrollNiftyX -= 1; if (scrollNiftyX < -widthNifty) scrollNiftyX += widthNifty;
    }
  }
  delay(12); 
}
