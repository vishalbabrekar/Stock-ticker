    if (dataNeedsUpdate) {
      if (xSemaphoreTake(dataMutex, 10) == pdTRUE) { 
        tft.fillScreen(TFT_BLACK); tft.setFont(&fonts::FreeSansBold12pt7b); tft.setTextColor(TFT_DARKGRAY);
