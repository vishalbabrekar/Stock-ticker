void processIncomingLine(const String &line, int &targetList) {
  if (line.length() == 0 || line.indexOf("GMT") != -1 || line.startsWith("<") || line.indexOf(":") != -1) return;
  if (line.indexOf("#NIFTY50") != -1) { targetList = 1; return; }
  if (line.indexOf("#BABA")    != -1) { targetList = 2; return; }
  if (line.indexOf("#AAI")     != -1) { targetList = 3; return; }
  String sym = extractToken(line, 0), prc = extractToken(line, 1), chg = extractToken(line, 2);
  if (sym == "" || prc == "" || chg == "") return;
  if (targetList == 1 && shadowNiftyCount < 50) shadowNifty[shadowNiftyCount++] = {sym, prc, chg};
  else if (targetList == 2 && shadowBabaCount < 100) shadowBaba[shadowBabaCount++] = {sym, prc, chg};
  else if (targetList == 3 && shadowAaiCount < 100) shadowAai[shadowAaiCount++] = {sym, prc, chg};
}

void printSystemStatusDirectly(const String &msg) {
  tft.fillScreen(TFT_BLACK); tft.setFont(&fonts::FreeSansBold12pt7b);
  tft.setTextColor(TFT_WHITE, TFT_BLACK); tft.setCursor(10, 140); tft.print(msg);
}

void networkBackgroundTask(void * pvParameters) {
  for(;;) {
    if (WiFi.status() == WL_CONNECTED) {
      http.setTimeout(15000); http.begin(secureClient, proxyUrl); 
      http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS); 
      int httpCode = http.GET();
      if (httpCode == HTTP_CODE_OK) { 
        WiFiClient* stream = http.getStreamPtr();
        int targetList = 0; shadowNiftyCount = 0; shadowBabaCount = 0; shadowAaiCount = 0; 
        String lineBuffer = ""; lineBuffer.reserve(64); unsigned long startTimeout = millis();
        while ((stream->available() || http.connected()) && (millis() - startTimeout < 10000)) {
          while (stream->available()) {
            char c = stream->read(); startTimeout = millis(); 
            if (c == '\n') { lineBuffer.trim(); processIncomingLine(lineBuffer, targetList); lineBuffer = ""; }
            else if (c != '\r' && lineBuffer.length() < 60) { lineBuffer += c; }
          }
          vTaskDelay(1 / portTICK_PERIOD_MS);
        }
        if (lineBuffer.length() > 0) { lineBuffer.trim(); processIncomingLine(lineBuffer, targetList); }
        if (shadowNiftyCount > 0 || shadowBabaCount > 0 || shadowAaiCount > 0) {
          if (xSemaphoreTake(dataMutex, portMAX_DELAY) == pdTRUE) {
            niftyCount = shadowNiftyCount; babaCount = shadowBabaCount; aaiCount = shadowAaiCount;
            for (int i = 0; i < niftyCount; i++) niftyList[i] = shadowNifty[i];
            for (int i = 0; i < babaCount; i++)  babaList[i]  = shadowBaba[i];
            for (int i = 0; i < aaiCount; i++)   aaiList[i]   = shadowAai[i];
            initialDataLoaded = true; 
            dataNeedsUpdate = true; // Flag Core 1 to refresh everything safely on its own thread
            xSemaphoreGive(dataMutex); 
          }
        }
      }
      http.end();
    }
    vTaskDelay(60000 / portTICK_PERIOD_MS);
  }
}

void setup() {
  Serial.begin(115200); tft.init(); tft.setRotation(1); tft.fillScreen(TFT_BLACK);
  tickerSprite.setColorDepth(8); tickerSprite.createSprite(480, 60); tickerSprite.setFont(&fonts::FreeSansBold18pt7b);
  secureClient.setInsecure(); WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { printSystemStatusDirectly("Connecting WiFi..."); delay(500); }
  printSystemStatusDirectly("Initializing Tapes...");
  dataMutex = xSemaphoreCreateMutex();
  xTaskCreatePinnedToCore(networkBackgroundTask, "NetWorker", 8192, NULL, 1, NULL, 0);
}

void loop() {
  unsigned long currentMillis = millis();
  if (initialDataLoaded) {
    // FIXED: Core 1 handles drawing modifications sequentially to eliminate ghost artifacts
    if (dataNeedsUpdate) {
      if (xSemaphoreTake(dataMutex, 10) == pdTRUE) { 
        tft.fillScreen(TFT_BLACK); // Clears the screen completely on the correct core thread
        preCalculateNiftyDimensions(); 
        drawTopStaticCards(); 
        dataNeedsUpdate = false; 
        xSemaphoreGive(dataMutex); 
      }
    }
    if (currentMillis - lastTopSwitchTime >= 4000) {
      if (babaCount > 0) currentBabaIndex = (currentBabaIndex + 1) % babaCount;
      if (aaiCount > 0)  currentAaiIndex = (currentAaiIndex + 1) % aaiCount;
      if (xSemaphoreTake(dataMutex, 5) == pdTRUE) { drawTopStaticCards(); xSemaphoreGive(dataMutex); }
      lastTopSwitchTime = currentMillis;
    }
    if (niftyCount > 0 && totalTickerWidth > 0) {
      tickerSprite.fillSprite(TFT_BLACK); int currentTextX = scrollX;
      while (currentTextX < 480) {
        for (int i = 0; i < niftyCount; i++) {
          if (currentTextX + itemWidths[i] >= 0 && currentTextX < 480) {
            tickerSprite.setTextColor(itemColors[i], TFT_BLACK); tickerSprite.drawString(buildNiftyItemString(i), currentTextX, 15);
          }
          currentTextX += itemWidths[i]; 
          if (currentTextX >= 480) break; 
        }
      }
      tickerSprite.pushSprite(0, 240); scrollX -= 2; 
      if (scrollX < -totalTickerWidth) scrollX += totalTickerWidth; 
    }
  }
  delay(12); 
}
