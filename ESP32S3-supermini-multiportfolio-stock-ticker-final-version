String extractToken(const String &data, int targetIndex) {
  int currentSegment = 0, startPos = 0;
  for (int i = 0; i <= data.length(); i++) {
    if (i == data.length() || data.charAt(i) == ',') {
      if (currentSegment == targetIndex) {
        String extracted = data.substring(startPos, i);
        extracted.trim(); return extracted;
      }
      startPos = i + 1; currentSegment++;
    }
  }
  return "";
}

String buildNiftyItemString(int i) {
  if (i >= niftyCount) return "";
  bool isNegative = (niftyList[i].change.indexOf('-') != -1);
  return niftyList[i].symbol + " " + niftyList[i].price + (isNegative ? "  v " : "  ^ ") + niftyList[i].change + " %      ";
}

void preCalculateNiftyDimensions() {
  if (niftyCount == 0) return;
  tft.setFont(&fonts::FreeSansBold18pt7b);
  totalTickerWidth = 0;
  for (int i = 0; i < niftyCount; i++) {
    itemColors[i] = (niftyList[i].change.indexOf('-') != -1) ? 0xF806 : 0x05E5; 
    itemWidths[i] = tft.textWidth(buildNiftyItemString(i));
    totalTickerWidth += itemWidths[i];
  }
}

